# Server Port
PORT=5000

# MongoDB URI connection string
# Local development: mongodb://127.0.0.1:27017/todoapp
# Production: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/todoapp

# Deployed Frontend URL (to restrict CORS)
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173
